  "terms": {
    "title": "Terms of Service",
    "backHome": "Back Home",
    "effectiveDate": "Effective date: April 27, 2026",
    "lastUpdated": "Last updated: April 27, 2026",
    "intro": "Please read these Terms of Service carefully before using Pactpay. By creating an account or using our platform, you agree to be bound by these terms.",
    "section1": {
      "title": "About Pactpay",
      "content1": "Pactpay is an escrow-protected contract platform that enables freelancers and clients to formalize work agreements and securely manage payments. Pactpay acts as a neutral third party that holds funds in escrow and releases them based on agreed milestones.",
      "content2": "Pactpay does not facilitate the introduction of clients and freelancers. Users bring their own working relationships to the platform."
    },
    "section2": {
      "title": "Eligibility",
      "subtitle": "To use Pactpay you must:",
      "item1": "Be at least 18 years of age",
      "item2": "Have the legal capacity to enter into binding contracts in your jurisdiction",
      "item3": "Provide accurate and truthful information during registration and KYC verification",
      "item4": "Not be prohibited from using financial services under applicable law"
    },
    "section3": {
      "title": "Account Registration & KYC",
      "content1": "To access the full features of Pactpay, you must complete our Know Your Customer (KYC) verification process. This includes providing:",
      "item1": "Your full legal name and date of birth",
      "item2": "A valid government-issued photo ID (National ID, Passport, or Driver's License)",
      "item3": "A selfie holding your ID document",
      "item4": "Your country of residence and contact information",
      "content2": "By submitting KYC documents, you confirm that all information provided is accurate, genuine and belongs to you. Submitting false or fraudulent documents will result in immediate account termination and may be reported to relevant authorities.",
      "content3": "KYC documents are reviewed by authorised Pactpay administrators only. Your documents will not be shared with any third parties except where required by law."
    }
  },
  "privacy": {
    "title": "Privacy Policy",
    "backHome": "Back Home",
    "effectiveDate": "Effective date: April 27, 2026",
    "lastUpdated": "Last updated: April 27, 2026",
    "intro": "Your privacy is of paramount importance to us. This Privacy Policy explains how Pactpay collects, uses, and protects your personal information when you use our platform.",
    "section1": {
      "title": "Information We Collect",
      "content1": "We collect information you provide directly to us when you create an account, complete KYC, or interact with our services:",
      "item1": "Identity Information: Name, date of birth, and government-issued ID documents for KYC verification.",
      "item2": "Contact Information: Email address and phone number.",
      "item3": "Financial Information: Wallet transactions, escrow balances, and withdrawal bank details.",
      "item4": "Usage Information: IP address, device details, and log data related to your activity on the platform."
    },
    "section2": {
      "title": "How We Use Your Information",
      "content1": "We use your information for the following purposes:",
      "item1": "To provide and maintain the Pactpay escrow services.",
      "item2": "To verify your identity (KYC) and prevent fraud or money laundering.",
      "item3": "To process transactions and manage escrow releases.",
      "item4": "To communicate with you about your account, contracts, and updates.",
      "item5": "To resolve disputes and enforce our Terms of Service.",
      "item6": "To comply with legal and regulatory requirements."
    },
    "section3": {
      "title": "KYC Data & Security",
      "content1": "The identity documents you provide during KYC are used solely for verification purposes. These documents are stored securely using industry-standard encryption.",
      "content2": "Access to your sensitive documents is strictly restricted to authorised Pactpay compliance administrators. We do not sell or lease your identity data to third-party marketing companies."
    }
  },
